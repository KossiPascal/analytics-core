[
    {
        "from": "orders",
        "joins": [
            {
                "type": "inner",
                "table": "users",
                "on": {
                    "left": "orders.user_id",
                    "right": "users.id"
                }
            },
            {
                "type": "left",
                "table": "countries",
                "on": {
                    "left": "users.country_id",
                    "right": "countries.id"
                }
            }
        ],
        "select": [
            {
                "field": "countries.name",
                "alias": "country"
            },
            {
                "field": "users.id",
                "agg": "count",
                "alias": "total_users"
            },
            {
                "field": "orders.amount",
                "agg": "sum",
                "alias": "total_revenue"
            },
            {
                "field": "orders.amount",
                "agg": "avg",
                "alias": "avg_order_value"
            }
        ],
        "filters": [
            {
                "field": "countries.name",
                "op": "in",
                "value": [
                    "France",
                    "Germany"
                ]
            },
            {
                "field": "orders.created_at",
                "op": "between",
                "value": [
                    "2024-01-01",
                    "2024-12-31"
                ]
            }
        ],
        "group_by": [
            "countries.name"
        ],
        "having": [
            {
                "field": "orders.amount",
                "op": ">",
                "value": 10000
            }
        ],
        "order_by": [
            {
                "field": "total_revenue",
                "direction": "desc"
            },
            {
                "field": "country",
                "direction": "asc"
            }
        ],
        "limit": 100,
        "offset": 0
    },
    {
        "from": "users",
        "select": [
            {
                "field": "data->>'name'",
                "alias": "username"
            },
            {
                "field": "data->'address'->>'city'",
                "alias": "city"
            },
            {
                "field": "data->>'age'",
                "agg": "avg",
                "alias": "avg_age"
            }
        ],
        "filters": [
            {
                "field": "data->>'country'",
                "op": "=",
                "value": "France"
            },
            {
                "field": "data->>'age'",
                "op": ">",
                "value": 18
            }
        ],
        "group_by": [
            "data->>'country'"
        ],
        "having": [
            {
                "field": "data->>'age'",
                "op": ">",
                "value": 21
            }
        ],
        "order_by": [
            {
                "field": "avg_age",
                "direction": "desc"
            },
            {
                "field": "city",
                "direction": "asc"
            }
        ],
        "limit": 50
    }
]