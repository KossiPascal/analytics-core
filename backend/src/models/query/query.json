# ===================== Définition des tables et champs =====================
tables = {
    "users": {"id", "name", "age", "salary", "country_id"},
    "countries": {"id", "name"}
}

dimensions = {"users.id", "users.name", "users.country_id", "countries.name"}
metrics = {"users.salary", "users.age"}

# ===================== JSON Query =====================
query = {
    "from": "users",
    "joins": [
        {
            "table": "countries",
            "type": "inner",
            "on": {"left": "users.country_id", "right": "countries.id"}
        }
    ],
    "select": [
        "users.id",
        {"field": "users.salary", "agg": "sum", "alias": "total_salary"},
        {"field": "users.age", "agg": "avg", "alias": "avg_age"},
        "countries.name"
    ],
    "filters": [
        {"field": "users.age", "op": "between", "value": [25, 50]},
        {"field": "countries.name", "op": "in", "value": ["USA", "Canada"]}
    ],
    "group_by": ["countries.name"],
    "having": [
        {"field": "users.salary", "op": ">", "value": 50000}
    ],
    "order_by": [
        {"field": "total_salary", "direction": "desc"}
    ],
    "limit": 100,
    "offset": 0
}

# ===================== Instanciation BIQueryEngine =====================
engine = BIQueryEngine(query=query, tables=tables, dimensions=dimensions, metrics=metrics, dialect="postgres")

# ===================== Validation =====================
try:
    engine.validate()
    print("✅ Query validated successfully")
except BIQueryError as e:
    print("❌ Validation Error:", e)

# ===================== Compilation =====================
sql, params = engine.compile()
print("\n🔹 SQL Generated (Postgres):\n", sql)
print("\n🔹 Params:\n", params)

# ===================== Compilation pour MySQL =====================
engine_mysql = BIQueryEngine(query=query, tables=tables, dimensions=dimensions, metrics=metrics, dialect="mysql")
engine_mysql.validate()
sql_mysql, params_mysql = engine_mysql.compile()
print("\n🔹 SQL Generated (MySQL):\n", sql_mysql)
print("\n🔹 Params (MySQL):\n", params_mysql)
