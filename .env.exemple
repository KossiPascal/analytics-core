# 🔹 Environnement Flask
# APP_ENV=production
APP_ENV=development

# 🔹 Dossiers projets
PROJECT_DATA_DIR=../analytics-data

SECRET_KEY=YOUR_SECRET_KEY
# 🔹 Informations de l'application
APP_VERSION=1
APP_NAME="ANALYTICS DASHBOARD APP"
APP_SUBNAME="ANALYTICS APP"

DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=district

# 🔹 Ports Nginx
NGINX_HTTP_PORT=8888
NGINX_HTTPS_PORT=4000

# 🔹 Clé JWT
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY

# 🔹 Clé API OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# 🔹 Configuration PostgreSQL En Local
LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5432
LOCAL_POSTGRES_DB=analytics_core_db
LOCAL_POSTGRES_USER=username
LOCAL_POSTGRES_PASSWORD=password

# 🔹 Configuration PostgreSQL
POSTGRES_HOST=analytics-core-postgres
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=analyticsdb
POSTGRES_PORT=5432
POSTGRES_NETWORK=analytics-core-net
DB_MINCONN=1
DB_MAXCONN=10

# 🔹 PGAdmin
PGADMIN_DEFAULT_EMAIL=email
PGADMIN_DEFAULT_PASSWORD=password
PGADMIN_PORT=4001

# 🔹 DBeaver
DBEAVER_ADMIN_NAME=username
DBEAVER_ADMIN_PASSWORD=password
DBEAVER_PORT=4002

COUCHDB_HOST=couchdbhost
COUCHDB_PORT=443
COUCHDB_USER=username
COUCHDB_PASS=password

# 🔹 Paramètres opérationnels
TIMEOUT=1600
MAX_RETRIES=3
RETRY_DELAY=3
BACK_OFF=2
MAX_WORKERS=50
















